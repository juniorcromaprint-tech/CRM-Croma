# Segredo compartilhado com as Supabase Edge Functions
NFE_INTERNAL_SECRET=gerar-um-uuid-aqui

# Certificado A1 em base64
# Para converter: base64 -w 0 certificado.pfx (Linux/Mac)
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("certificado.pfx"))
NFE_CERT_BASE64=

# Senha do certificado A1
NFE_CERT_PASSWORD=

# CNPJ do emitente (so numeros)
NFE_CNPJ_EMITENTE=18923994000183

# Ambiente: 1=Producao, 2=Homologacao
NFE_AMBIENTE=2

# UF do emitente
NFE_UF=SP

# Razao social
NFE_RAZAO_SOCIAL=CROMA PRINT COMUNICACAO VISUAL LTDA

# Endereco
NFE_ENDERECO=RUA PAULO OROZIMBO
NFE_NUMERO=424
NFE_BAIRRO=ACLIMACAO
NFE_MUNICIPIO=SAO PAULO
NFE_COD_IBGE=3550308
NFE_CEP=01535000

# Inscricao Estadual
NFE_IE=142826237111

# Regime Tributario: 1=Simples Nacional, 3=Lucro Real/Presumido
NFE_CRT=1
