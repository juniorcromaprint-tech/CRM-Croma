# ─── Croma MCP Server — Variáveis de Ambiente ────────────────────────────────
#
# Copie este arquivo para .env e preencha os valores.
# O .env NÃO deve ser commitado (está no .gitignore).
#
# Para uso no Claude Desktop, configure estas variáveis em:
#   claude_desktop_config.json → mcpServers → croma-erp → env
#
# Exemplo de configuração no claude_desktop_config.json:
#   "croma-erp": {
#     "command": "node",
#     "args": ["C:/caminho/para/mcp-server/dist/index.js"],
#     "env": {
#       "SUPABASE_SERVICE_ROLE_KEY": "...",
#       "SUPABASE_USER_PASSWORD": "..."
#     }
#   }

# ─── Obrigatório ──────────────────────────────────────────────────────────────

# Service role key do Supabase (Admin API — bypass total de RLS)
# Encontre em: supabase.com/dashboard/project/djwjmfgplnqyffdcgdaw/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# ─── Recomendado (user auth para writes) ─────────────────────────────────────
#
# Sem estas variáveis, o MCP usa service_role para TUDO:
#   - Reads: funcionam normalmente
#   - Writes: auth.uid() será NULL em triggers, vendedor_id não é populado,
#             registros criados podem não aparecer corretamente no frontend
#
# Com estas variáveis, o MCP autentica como Junior antes de writes:
#   - auth.uid() retorna o UUID real do usuário
#   - Triggers populam vendedor_id, created_by, etc. corretamente
#   - Registros aparecem normalmente no ERP

# Email do usuário admin (padrão: junior.cromaprint@gmail.com)
SUPABASE_USER_EMAIL=junior.cromaprint@gmail.com

# Senha do usuário admin no Supabase Auth
SUPABASE_USER_PASSWORD=
