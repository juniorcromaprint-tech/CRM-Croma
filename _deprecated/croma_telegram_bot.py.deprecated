# ─── Config ───────────────────────────────────────────────────────────────────
def carregar_config() -> dict:
    if not CONFIG_FILE.exists():
        log.error(f"Config não encontrado: {CONFIG_FILE}")
        sys.exit(1)
    with open(CONFIG_FILE, encoding="utf-8") as f:
        cfg = json.load(f)
    for campo in ("telegram_token", "openrouter_api_key"):
        if not cfg.get(campo):
            log.error(f"Campo obrigatório ausente: {campo}")
            sys.exit(1)
    return cfg


# ─── Supabase REST client ─────────────────────────────────────────────────────
class SupabaseClient:
    def __init__(self, url: str, key: str):
        self.url = url.rstrip("/")
        self.headers = {
            "apikey": key,
            "Authorization": f"Bearer {key}",
            "Content-Type": "application/json",
            "Prefer": "return=representation",
        }

    def select(self, table: str, columns: str = "*", filters: dict | None = None, limit: int = 20) -> list:
        params: dict = {"select": columns, "limit": limit}
        if filters:
            params.update(filters)
        try:
            r = requests.get(f"{self.url}/rest/v1/{table}", headers=self.headers, params=params, timeout=15)
            r.raise_for_status()
            return r.json() if isinstance(r.json(), list) else []
        except Exception as e:
            log.error(f"Supabase select {table}: {e}")
            return []

    def insert(self, table: str, data: dict) -> dict | None:
        try:
            r = requests.post(f"{self.url}/rest/v1/{table}", headers=self.headers, json=data, timeout=15)
            r.raise_for_status()
            result = r.json()
            return result[0] if isinstance(result, list) and result else result
        except Exception as e:
            log.error(f"Supabase insert {table}: {e}")
            return None


# ─── Telegram Bot ─────────────────────────────────────────────────────────────
class TelegramBot:
    def __init__(self, token: str):
        self.token  = token
        self.base   = f"https://api.telegram.org/bot{token}"
        self.offset = 0

    def _post(self, endpoint: str, payload: dict) -> dict:
        try:
            r = requests.post(f"{self.base}/{endpoint}", json=payload, timeout=15)
            return r.json()
        except Exception as e:
            log.error(f"Telegram {endpoint}: {e}")
            return {}

    def get_updates(self, timeout: int = 25) -> list:
        try:
            r = requests.get(
                f"{self.base}/getUpdates",
                params={"offset": self.offset, "timeout": timeout},
                timeout=timeout + 10,
            )
            return r.json().get("result", [])
        except Exception as e:
            log.error(f"get_updates: {e}")
            return []

    def send(self, chat_id: int, text: str, parse_mode: str = "Markdown"):
        for i in range(0, max(len(text), 1), 4000):
            chunk = text[i: i + 4000]
            self._post("sendMessage", {"chat_id": chat_id, "text": chunk, "parse_mode": parse_mode})
            if len(text) > 4000:
                time.sleep(0.3)

    def typing(self, chat_id: int):
        self._post("sendChatAction", {"chat_id": chat_id, "action": "typing"})

    def get_me(self) -> dict:
        try:
            r = requests.get(f"{self.base}/getMe", timeout=10)
            return r.json().get("result", {})
        except Exception:
            return {}

    def get_file_url(self, file_id: str) -> str:
        try:
            r = requests.get(f"{self.base}/getFile", params={"file_id": file_id}, timeout=10)
            path = r.json().get("result", {}).get("file_path", "")
            return f"https://api.telegram.org/file/bot{self.token}/{path}" if path else ""
        except Exception:
            return ""


# ─── Estado por chat ──────────────────────────────────────────────────────────
historicos:             dict[int, list] = {}
modelos_chat:           dict[int, str]  = {}
tokens_chat:            dict[int, dict] = {}
pending_confirmations:  dict[int, dict] = {}


def modelo_atual(chat_id: int) -> str:
    return modelos_chat.get(chat_id, MODELO_HAIKU)


def registrar_tokens(chat_id: int, inp: int, out: int):
    t = tokens_chat.setdefault(chat_id, {"input": 0, "output": 0, "chamadas": 0})
    t["input"] += inp
    t["output"] += out
    t["chamadas"] += 1


def custo_estimado(chat_id: int) -> float:
    modelo = modelo_atual(chat_id)
    t = tokens_chat.get(chat_id, {"input": 0, "output": 0})
    c = CUSTO.get(modelo, CUSTO[MODELO_HAIKU])
    return (t["input"] * c["input"] + t["output"] * c["output"]) / 1000


